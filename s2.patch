+// ——— VIEW: Calendário ———
+function viewCalendario() {
+  const d = new Date();
+  renderCalendario(d.getFullYear(), d.getMonth());
+}
+
+function renderCalendario(year, month) {
+  const missions = Store.get('missions') || [];
+  const months = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
+  const dow = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
+
+  const firstDay = new Date(year, month, 1).getDay();
+  const daysInMonth = new Date(year, month + 1, 0).getDate();
+  const hojeStr = today();
+  const hojeNum = parseInt(hojeStr.slice(8,10));
+  const hojeMes = parseInt(hojeStr.slice(5,7)) - 1;
+  const hojeAno = parseInt(hojeStr.slice(0,4));
+
+  // Build map of dates with completed missions
+  const missionDays = {};
+  missions.forEach(m => {
+    if (m.done && m.completedAt) {
+      const d = m.completedAt.slice(0,10);
+      if (!missionDays[d]) missionDays[d] = [];
+      missionDays[d].push(m);
+    }
+  });
+
+  // Current streak days (consecutive days ending today)
+  const streakDays = getStreakDays(missions);
+
+  let cells = dow.map(d => `<div class="dow">${d}</div>`).join('');
+  for (let day = 1; day <= daysInMonth; day++) {
+    const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
+    const isToday = day === hojeNum && month === hojeMes && year === hojeAno;
+    const hasMissions = !!missionDays[dateStr];
+    const isStreakDay = streakDays.includes(dateStr);
+
+    cells += `<div class="cell${isToday?' today':''}${hasMissions?' on':''}" data-action="cal-day" data-date="${dateStr}">
+      <span style="font-size:13px;font-weight:600;">${day}</span>
+      <span style="display:flex;gap:2px;font-size:9px;line-height:1;">${hasMissions?'<span style="color:var(--success);">●</span>':''}${isStreakDay?'<span>🔥</span>':''}</span>
+    </div>`;
+  }
+
+  document.getElementById('view').innerHTML = `
+    <div class="between" style="margin-bottom:16px;">
+      <button class="btn ghost" data-action="cal-prev">◀ ${months[month-1 < 0 ? 11 : month-1].slice(0,3)}</button>
+      <h2 style="font-weight:800;">${months[month]} ${year}</h2>
+      <button class="btn ghost" data-action="cal-next">${months[(month+1)%12].slice(0,3)} ▶</button>
+    </div>
+    <div class="cal">${cells}</div>
+    <div id="cal-detail" style="margin-top:16px;"></div>`;
+
+  bindActions(document.getElementById('view'), {
+    'cal-prev'() {
+      let m = month - 1, y = year;
+      if (m < 0) { m = 11; y--; }
+      renderCalendario(y, m);
+    },
+    'cal-next'() {
+      let m = month + 1, y = year;
+      if (m > 11) { m = 0; y++; }
+      renderCalendario(y, m);
+    },
+    'cal-day'(e, el) {
+      const date = el.dataset.date;
+      const dayMissions = missionDays[date] || [];
+      const detailEl = document.getElementById('cal-detail');
+      if (detailEl.innerHTML && detailEl.dataset.date === date) {
+        detailEl.innerHTML = '';
+        detailEl.dataset.date = '';
+      } else {
+        const diffColor = { facil:'var(--success)', media:'var(--gold)', dificil:'var(--danger)' };
+        detailEl.innerHTML = `
+          <div class="card">
+            <div class="between" style="margin-bottom:8px;">
+              <h3>📅 ${date}</h3>
+              <button class="btn ghost sm" data-action="cal-detail-close">${icon('x')}</button>
+            </div>
+            ${dayMissions.length ? dayMissions.map(m => `
+              <div class="lrow" style="margin-bottom:6px;">
+                <div class="lic" style="background:${diffColor[m.difficulty]||'var(--surface-3)'};">${icon('check')}</div>
+                <div class="lbody">
+                  <div class="ltitle">${escHtml(m.title)}</div>
+                  <div class="lsub">${DIFFICULTIES[m.difficulty]?.label||''} · +${m.reward?.xp||0}XP · +${m.reward?.coins||0} moedas</div>
+                </div>
+              </div>`).join('') : '<div class="muted">Nenhuma missão neste dia.</div>'}
+          </div>`;
+        detailEl.dataset.date = date;
+        // Bind the close button
+        detailEl.querySelector('[data-action=cal-detail-close]')?.addEventListener('click', () => {
+          detailEl.innerHTML = '';
+          detailEl.dataset.date = '';
+        });
+      }
+    },
+  });
+}
+
+function getStreakDays(missions) {
+  const dates = [...new Set(missions.filter(m => m.done && m.completedAt).map(m => m.completedAt.slice(0,10)))].sort();
+  const streak = [];
+  const cursor = new Date(today() + 'T12:00:00');
+  for (let i = 0; i < 365; i++) {
+    const ds = cursor.toISOString().slice(0,10);
+    if (dates.includes(ds)) { streak.push(ds); cursor.setDate(cursor.getDate() - 1); }
+    else break;
+  }
+  return streak;
 }
 
